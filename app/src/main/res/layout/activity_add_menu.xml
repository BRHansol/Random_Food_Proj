<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E6"
    tools:context=".AddMenuActivity">

    <FrameLayout
        android:id="@+id/header"
        android:layout_width="409dp"
        android:layout_height="144dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/b1" />


        <!-- ข้อความทับรูป -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="48dp"
                android:layout_height="41dp"
                app:srcCompat="@drawable/ic_back1" />

            <TextView
                android:id="@+id/txtTitle3"
                android:layout_width="347dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Add Menu"
                android:textColor="#000"
                android:textSize="32sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- การ์ดพื้นขาว -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_card"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- เลือกไอคอน -->
                <TextView
                    android:id="@+id/txticon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="เลือกไอคอน"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- ไอคอน 1 -->
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="12dp"
                            android:src="@drawable/rice"
                            android:contentDescription="rice"/>

                        <!-- เพิ่มไอคอนอื่น ๆ แบบเดียวกัน -->
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="12dp"
                            android:src="@drawable/noodle"
                            android:contentDescription="noodle"/>

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="12dp"
                            android:src="@drawable/pizza"
                            android:contentDescription="pizza"/>

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="12dp"
                            android:src="@drawable/spaghetti"
                            android:contentDescription="spaghetti"/>

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="12dp"
                            android:src="@drawable/burrito"
                            android:contentDescription="burrito"/>

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="12dp"
                            android:src="@drawable/kfc"
                            android:contentDescription="kfc"/>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- ชื่อลิสต์ -->
                <TextView
                    android:id="@+id/txtNameList"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="ชื่อลิสต์"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtnameList"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="ชื่อลิสต์"
                    android:padding="12dp" />

                <!-- รายการ -->
                <TextView
                    android:id="@+id/txtitem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="รายการ"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtitem1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:hint="ชื่อรายการ"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/edtitem2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:hint="ชื่อรายการ"
                    android:padding="12dp" />

                <!-- ปุ่มเพิ่มรายการ -->
                <Button
                    android:id="@+id/btnAdditem"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:text="+ เพิ่มรายการ" />

            </LinearLayout>

            <!-- ปุ่มบันทึก -->
            <Button
                android:id="@+id/btnAddmenu"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#F2995A"
                android:text="บันทึกเมนู"
                android:textColor="#FFF"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>