<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF3E6">
    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/b1"
            android:scaleType="centerCrop"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="MY Menu"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </FrameLayout>
    <!-- Tabs -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/frameLayout">

        <Button
            android:id="@+id/btnMenu"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:backgroundTint="#E0D5C9"
            android:text="เมนูของคุณ" />

        <Button
            android:id="@+id/btnFavorite"
            android:layout_width="130dp"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:backgroundTint="#DDD"
            android:text="รายการโปรด" />

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:backgroundTint="#E08A5B"
            android:text="ประวัติ"
            android:textColor="#000" />
    </LinearLayout>


    <!-- Card History -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="15dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="4dp"
        android:backgroundTint="#E8D6BF">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            tools:listitem="@layout/item_history"/>

    </androidx.cardview.widget.CardView>

    <!-- Bottom Bar แบบง่าย -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FFE0C2"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnHome"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home" />

        <Space
            android:layout_width="60dp"
            android:layout_height="wrap_content" />

        <ImageView
            android:id="@+id/btnAdd"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_add" />

        <Space
            android:layout_width="60dp"
            android:layout_height="wrap_content" />

        <ImageView
            android:id="@+id/btnProfile"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_prof" />

    </LinearLayout>
</LinearLayout>